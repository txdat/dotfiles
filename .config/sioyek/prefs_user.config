enable_experimental_features    1
use_heuristic_if_text_summary_not_available 1

#background_color    1.0 1.0 1.0
#dark_mode_background_color  0.0 0.0 0.0
#dark_mode_contrast  1.0
#custom_background_color 0.102 0.106 0.149
#custom_text_color   0.753 0.792 0.961
#default_dark_mode   1

ui_font     JetbrainsMono Nerd Font Mono
font_size   24

ruler_mode  1
linear_filter   1
display_resolution_scale    1
should_launch_new_window    1

#startup_commands    toggle_custom_color;toggle_visual_scroll;toggle_mouse_drag_mode;toggle_horizontal_scroll_lock;
startup_commands    toggle_visual_scroll;toggle_mouse_drag_mode;toggle_horizontal_scroll_lock;
