[settings]
screenchange-reload	= true

[global/wm]
margin-top			= 0
margin-bottom		= 0

[bar/main]
width			= 100%
height			= 25
radius			= 0
fixed-center		= true

background		= #1E2022 
foreground		= #F0F5F9

line-size		= 3
line-color		= #f00

border-size		= 0
border-color		= #1E2022

padding-left		= 0
padding-right		= 0

module-margin-left	= 0
module-margin-right	= 0

font-0			= "Cascadia Code:size=10;2" 
font-1			= "icomoon-feather:size=10;2"
font-2 			= "Material:size=10;2"
font-3			= "xos4 Terminus:size=10;2"

modules-left		= bspwm
;modules-center		= 
modules-right		= battery pulseaudio wlan date

wm-restack		= bspwm

scroll-up		= bspwm-desknext
scroll-down		= bspwm-deskprev

cursor-click		= pointer
;cursor-scroll		= ns-resize

[module/bspwm]
include-file		= ~/.config/polybar/bspwm.ini

[module/pulseaudio]
include-file		= ~/.config/polybar/pulseaudio.ini

[module/wlan]
include-file		= ~/.config/polybar/wlan.ini

[module/battery]
include-file		= ~/.config/polybar/battery.ini

[module/date]
include-file		= ~/.config/polybar/date.ini
