Config {
	-- appearance
	font				= "xft:Cascadia Code:size=12:antialias=true:hinting=true",
	additionalFonts		= [ "xft:Font Awesome 5 Free:style=Solid,Font Awesome 5 Free,Font Awesome 5 Brands" ],
	position			= Top,
	bgColor				= "#000000",
	fgColor				= "#FFFFFF", -- font color

	-- behavior
	lowerOnStart		= True,
	hideOnStart			= False,
	allDesktops			= True,
	overrideRedirect 	= True,
	pickBroadest		= False,
	persistent			= True,

	-- layout
	sepChar				= "%",
	alignSep			= "}{",
	template			= "%StdinReader% }{ | %enp0s31f6% %wlp0s20f3wi% | %default:Master% | %bright% | %battery% | %date%",

	-- plugins
	commands 			= [
		Run StdinReader,

		Run Wireless "wlp0s20f3"	[ "-t", "<fn=1>\xf1eb</fn> <essid>" ] 50,

		Run Network "enp0s31f6" 	[ "-t", "<fn=1>\xf796</fn>" ] 50,

		Run Volume "default" "Master"	[
			"-t", "<status>",
			"--", "-O", "<fn=1>\xf028</fn> <volume>%",
				  "-o", "<fc=#6c0405><fn=1>\xf6a9</fn> <volume>%</fc>"
		] 10,

		Run Brightness	[ "-t", "<fn=1>\xf185</fn> <percent>%", "--", "-D", "intel_backlight" ] 10,

		Run	Battery 	[
			"-t", "<acstatus>",
			"-L", "10",
			"-H", "80",
			"--", "-o", "<fn=1>\xf241</fn> <left>%", 
				  "-O", "<fc=#daa520><fn=1>\xf241</fn> <left>%</fc>", 
				  "-i", "<fc=#006000><fn=1>\xf240</fn> <left>%</fc>"
		] 50,

		Run Date		"<fn=1>\xf017</fn> (%a) %m/%d/%y %I:%M %p"	"date"	100 -- update after 10s
	]
}
